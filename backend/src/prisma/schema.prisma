generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GERENCIA
  ADMINISTRADOR
  TIENDA
}

enum DeviceStatus {
  ACTIVO
  PAGO_PENDIENTE
  SOLO_LLAMADAS
  BLOQUEADO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

enum CreditContractStatus {
  ACTIVO
  CERRADO
  CANCELADO
}

enum InstallmentStatus {
  PENDIENTE
  REPORTADO
  PAGADO
  VENCIDO
  CANCELADO
}

enum EquifaxConsultationStatus {
  PENDIENTE
  RESPONDIDA
}

enum DeletionRequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

model User {
  id            String                @id @default(cuid())
  username      String                @unique
  passwordHash  String
  fullName      String?
  avatarDataUrl String?               @db.Text
  role          UserRole              @default(ADMIN)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  statusChanges DeviceStatusHistory[]
  customers     Customer[]            @relation("CustomerCreatedBy")
  equifaxRequests EquifaxConsultation[] @relation("EquifaxRequestedBy")
  equifaxResponses EquifaxConsultation[] @relation("EquifaxRespondedBy")
  deletionRequests DeletionRequest[]     @relation("DeletionRequestedBy")
  deletionResolutions DeletionRequest[]  @relation("DeletionResolvedBy")
}

model Customer {
  id              String           @id @default(cuid())
  fullName        String
  nationalId      String           @unique
  phone           String
  referencePersonalPhone1 String?
  referencePersonalPhone2 String?
  referenceWorkPhone      String?
  address         String?
  notes           String?
  createdByUserId String?
  createdByUser   User?            @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  devices         Device[]
  payments        Payment[]
  creditContracts CreditContract[]
  assets          CustomerAsset[]

  @@index([createdByUserId])
}

model CustomerAsset {
  id        String   @id @default(cuid())
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category  String
  fileName  String
  mimeType  String
  fileSize  Int
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, category, createdAt])
}

model Device {
  id                 String              @id @default(cuid())
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  brand              String
  model              String
  alias              String?
  imei               String              @unique
  imei2              String?             @unique
  installCode        String              @unique
  hexnodeDeviceId    Int?                @unique
  clientSecret       String              @unique @default(uuid())
  currentStatus      DeviceStatus        @default(ACTIVO)
  manualStatusOverride Boolean           @default(false)
  manualStatusReason String?
  manualStatusChangedAt DateTime?
  lastStatusChangeAt DateTime            @default(now())
  isRegistered       Boolean             @default(false)
  lastSeenAt         DateTime?
  pushToken          String?
  pushTokenUpdatedAt DateTime?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  payments           Payment[]
  statusHistory      DeviceStatusHistory[]
  creditContract     CreditContract?
}

model Payment {
  id         String        @id @default(cuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deviceId   String
  device     Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  amount     Decimal       @db.Decimal(10, 2)
  currency   String        @default("USD")
  dueDate    DateTime
  paidAt     DateTime?
  status     PaymentStatus @default(PENDIENTE)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  installment Installment?

  @@index([deviceId, dueDate])
  @@index([customerId, dueDate])
}

model CreditContract {
  id               String               @id @default(cuid())
  customerId       String
  customer         Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deviceId         String               @unique
  device           Device               @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  principalAmount  Decimal              @db.Decimal(10, 2)
  downPaymentAmount Decimal             @db.Decimal(10, 2) @default(0)
  financedAmount   Decimal              @db.Decimal(10, 2) @default(0)
  installmentCount Int
  installmentAmount Decimal             @db.Decimal(10, 2)
  currency         String               @default("USD")
  purchaseDate     DateTime
  startDate        DateTime
  status           CreditContractStatus @default(ACTIVO)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  installments     Installment[]

  @@index([customerId])
  @@index([status])
}

model Installment {
  id         String            @id @default(cuid())
  contractId String
  contract   CreditContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  sequence   Int
  dueDate    DateTime
  amount     Decimal           @db.Decimal(10, 2)
  status     InstallmentStatus @default(PENDIENTE)
  reportedAt DateTime?
  paidAt     DateTime?
  notes      String?
  paymentId  String?           @unique
  payment    Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([contractId, sequence])
  @@index([contractId, dueDate])
  @@index([status, dueDate])
}

model DeviceStatusHistory {
  id              String       @id @default(cuid())
  deviceId        String
  device          Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  previousStatus  DeviceStatus?
  newStatus       DeviceStatus
  changedByUserId String?
  changedByUser   User?        @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)
  reason          String?
  createdAt       DateTime     @default(now())

  @@index([deviceId, createdAt])
}

model TrashEntry {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  summary         String?
  payload         Json?
  deletedByUserId String?
  deleteAfter     DateTime
  createdAt       DateTime @default(now())

  @@index([deleteAfter])
  @@index([entityType, entityId])
}

model EquifaxConsultation {
  id                String                    @id @default(cuid())
  queryNationalId   String
  queryFullName     String
  queryNotes        String?
  status            EquifaxConsultationStatus @default(PENDIENTE)
  responseNationalId String?
  responseFullName  String?
  hasGoodCredit     Boolean?
  highEndPhoneEligible Boolean?
  maxDebtAmount     Decimal?                  @db.Decimal(10, 2)
  responseNotes     String?
  requestedByUserId String?
  requestedByUser   User?                     @relation("EquifaxRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  respondedByUserId String?
  respondedByUser   User?                     @relation("EquifaxRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)
  respondedAt       DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([status, createdAt])
  @@index([queryNationalId])
}

model DeletionRequest {
  id                  String                @id @default(cuid())
  entityType          String
  entityId            String
  summary             String?
  observation         String
  status              DeletionRequestStatus @default(PENDIENTE)
  requestedByUserId   String?
  requestedByUser     User?                 @relation("DeletionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  resolvedByUserId    String?
  resolvedByUser      User?                 @relation("DeletionResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolutionNotes     String?
  resolvedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([entityType, entityId])
}
