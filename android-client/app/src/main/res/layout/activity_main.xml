<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/rootContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KOVIX Device Client"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cliente Android para sincronizar estado del equipo" />

            <TextView
                android:id="@+id/adminModeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Modo de control: ESTANDAR"
                android:textColor="#92400E"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/baseUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Base URL (ej: http://10.0.2.2:4000)"
                android:inputType="textUri" />

            <EditText
                android:id="@+id/installCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Install Code"
                android:inputType="text" />

            <EditText
                android:id="@+id/clientSecretInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Client Secret"
                android:inputType="textPassword" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/saveConfigButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Guardar config" />

                <Button
                    android:id="@+id/syncNowButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Sincronizar" />
            </LinearLayout>

            <Button
                android:id="@+id/unlockConfigButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Desbloquear config (Admin)" />

            <TextView
                android:id="@+id/statusTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Estado: SIN_DATOS"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Sincroniza para obtener estado del servidor." />

            <TextView
                android:id="@+id/customerNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cliente: -" />

            <TextView
                android:id="@+id/lastSyncText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ultima sync: -" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#B91C1C"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/restrictionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/restrictionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modo operativo"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/restrictionDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sin restricciones activas." />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/creditCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#EFF6FF"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/creditTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mi credito"
                    android:textColor="#1E3A8A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/creditDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sin contrato activo." />

                <Button
                    android:id="@+id/reportPaymentButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Reportar pago de cuota" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/callsOnlyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FEF3C7"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/callsOnlyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="MODO SOLO LLAMADAS"
            android:textColor="#92400E"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/callsOnlyDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Tu equipo esta restringido. Regulariza tu pago para volver al modo normal."
            android:textColor="#78350F"
            android:textSize="18sp" />

        <Button
            android:id="@+id/callsOnlySyncButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sincronizar ahora" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FEE2E2"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/lockTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="DISPOSITIVO BLOQUEADO"
            android:textColor="#991B1B"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lockDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Regulariza pagos para restablecer el servicio."
            android:textColor="#7F1D1D"
            android:textSize="18sp" />

        <Button
            android:id="@+id/lockRetryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Reintentar sincronizacion" />
    </LinearLayout>
</FrameLayout>
